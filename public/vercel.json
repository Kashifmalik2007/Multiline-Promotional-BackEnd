{
  "rewrites": [
    {
      "source": "/attached_assets/:path*",
      "destination": "https://multiline-promotional-backend.onrender.com/attached_assets/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://multiline-promotional-backend.onrender.com/attached_assets/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://multiline-promotional-backend.onrender.com/api/:path*"
    }
  ]
}
